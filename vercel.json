{
  "version": 2,
  "builds": [
    { "src": "api/chat.js",  "use": "@vercel/node" },
    { "src": "api/lead.js",  "use": "@vercel/node" },
    { "src": "*.html",       "use": "@vercel/static" },
    { "src": "*.js",         "use": "@vercel/static" },
    { "src": "uploads/**",   "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/lead", "dest": "/api/lead.js" },
    { "src": "/(.*)",     "dest": "/$1" }
  ]
}
